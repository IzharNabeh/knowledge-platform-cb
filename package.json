{
  "name": "@knowledge-platform/chat-widget",
  "version": "0.1.0",
  "description": "Embeddable AI chat widget for Angular and other web applications.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "default": "./dist/browser.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/browser.js"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "dev:mock": "node local-test/mock-ai-server.js"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.8.3"
  }
}
